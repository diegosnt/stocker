{
  "name": "stocker",
  "version": "1.0.0",
  "description": "Registro de operaciones bursátiles",
  "main": "api/server.js",
  "scripts": {
    "dev": "concurrently -n \"server,client\" -c \"blue,green\" \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch api/server.js",
    "build": "vite build",
    "start": "node api/server.js",
    "setup": "node scripts/download-deps.js"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "chartjs-chart-treemap": "^3.1.0",
    "compression": "^1.8.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "jose": "^6.1.3",
    "pino": "^10.3.1",
    "sanitize-html": "^2.13.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react-swc": "^4.3.0",
    "concurrently": "^9.2.1",
    "pino-pretty": "^13.1.3",
    "vite": "^8.0.9"
  }
}
